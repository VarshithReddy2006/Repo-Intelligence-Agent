{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "lib": ["ES2020", "dom"],
    "outDir": "./out",
    "rootDir": "./src",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "types": ["node", "mocha"]
  },
  "exclude": [
    "node_modules",
    ".vscode-test",
    "out",
    "webview"
  ],
  "include": [
    "src/**/*.ts"
  ]
}
