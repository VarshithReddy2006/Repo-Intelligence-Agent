# =============================================================================
# LLM Provider — choose one: "gemini" (default) or "deepseek"
# =============================================================================
LLM_PROVIDER=gemini

# Google Gemini (default provider — recommended)
# Get your API key from https://aistudio.google.com/app/apikey
# The key must be a Google AI Studio Developer API key (starts with AIza...)
# Not an OAuth token, not a service account credential.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# DeepSeek V4 Flash via NVIDIA NIM (alternative provider)
# Get your NVIDIA NIM API key from https://build.nvidia.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://integrate.api.nvidia.com/v1
DEEPSEEK_MODEL=deepseek-ai/deepseek-v4-flash

# =============================================================================
# GitHub Configuration
# =============================================================================
# Recommended: PAT for cloning private repos and raising the API rate limit
# (authenticated: 5000 req/hr vs unauthenticated: 60 req/hr)
# Required scopes: contents:read, metadata:read
GITHUB_TOKEN=your_github_pat_here

# =============================================================================
# Storage Settings
# =============================================================================
SQLITE_DB_PATH=data/repo_understanding.db   # SQLite relational storage
CHROMA_DB_PATH=data/chroma_db               # ChromaDB vector store

# IMPORTANT: Set CLONED_REPOS_PATH to a location OUTSIDE the project tree.
# If left inside the project (e.g. data/cloned_repos), uvicorn's WatchFiles
# will detect new files during cloning and trigger a reload, killing in-flight
# analysis requests.
#
# Examples:
#   Windows:      C:/repo_intelligence_storage/cloned_repos
#   Linux/macOS:  /var/lib/repo_intelligence/cloned_repos
#
# Leave blank to use the default: ~/.repo_intelligence/cloned_repos
CLONED_REPOS_PATH=

# =============================================================================
# API Server Settings
# =============================================================================
API_SERVER_HOST=0.0.0.0   # Uvicorn bind host
API_SERVER_PORT=8001       # Uvicorn bind port

# =============================================================================
# Application Settings
# =============================================================================
# "development" — startup continues with warning if LLM providers are unhealthy
# "production"  — startup fails fast if all LLM providers are unhealthy
APP_ENV=development

# Logging
LOG_LEVEL=INFO            # DEBUG, INFO, WARNING, ERROR
LOG_FORMAT=human          # "human" for development, "json" for production

# =============================================================================
# Security Settings
# =============================================================================
# Rate limiting: max requests per IP per minute (0 = disabled)
# RateLimiter uses a thread-safe periodic cleanup sweep to prevent memory leaks.
RATE_LIMIT_PER_MINUTE=60

# Optional API Key authentication for expensive endpoints:
# Leaves blank (or comment out) to disable authentication.
# API_KEY=your_secret_api_key_here

# Trusted hostnames for TrustedHostMiddleware (JSON array)
# In production, set this to your actual API domain:
# ALLOWED_HOSTS=["api.yourdomain.com"]
ALLOWED_HOSTS=["*"]

# =============================================================================
# Frontend / CORS Settings
# =============================================================================
# The CORS allowed origin for the frontend.
# In production, set this to your actual frontend domain:
# FRONTEND_URL=https://app.yourdomain.com
FRONTEND_URL=http://localhost:4321

# =============================================================================
# Advanced Settings (optional)
# =============================================================================
# Embedding model — do not change unless you have a compelling reason.
# Changing the model requires deleting data/chroma_db and re-indexing all repos.
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Maximum analysis build timeout in seconds (default: 30 minutes)
# BUILD_TIMEOUT=1800

# In-memory cache size limit (number of entries, default: 1000)
# CACHE_SIZE_LIMIT=1000

# Shared cache file path (planned future use)
# CACHE_FILE_PATH=data/cache.json

# Number of parallel worker threads for the execution runner (default: auto)
# WORKER_COUNT=4
