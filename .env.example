# =============================================================================
# LLM Provider — DeepSeek V4 Flash via NVIDIA NIM
# =============================================================================
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your_nvidia_nim_api_key_here
DEEPSEEK_BASE_URL=https://integrate.api.nvidia.com/v1
DEEPSEEK_MODEL=deepseek-ai/deepseek-r1

# =============================================================================
# GitHub Configuration
# =============================================================================
GITHUB_TOKEN=your_github_personal_access_token_here   # [Used] PAT for cloning and API access
GITHUB_REPOSITORY=owner/repo                           # [Unused]

# =============================================================================
# Memory & Storage Settings
# =============================================================================
SQLITE_DB_PATH=data/repo_understanding.db   # [Planned] SQLite relational storage path
CHROMA_DB_PATH=data/chroma_db               # [Used] ChromaDB persistence directory
CACHE_FILE_PATH=data/cache.json             # [Planned] Shared cache layer path
# [Used] Where to clone analyzed repos. MUST be outside the project tree —
# otherwise uvicorn --reload's WatchFiles fires on every cloned file and kills
# the in-flight analysis. Examples:
#   Windows: C:/repo_intelligence_storage/cloned_repos
#   Linux/macOS: /var/lib/repo_intelligence/cloned_repos
# Leave blank to default to ~/.repo_intelligence/cloned_repos.
CLONED_REPOS_PATH=

# =============================================================================
# API Server Settings
# =============================================================================
API_SERVER_PORT=8001    # [Used] Configures the uvicorn port in backend/main.py
API_SERVER_HOST=0.0.0.0 # [Used] Configures the uvicorn host in backend/main.py

# =============================================================================
# Frontend Settings
# =============================================================================
FRONTEND_URL=http://localhost:4321   # [Unused] CORS currently allows all origins (*)
