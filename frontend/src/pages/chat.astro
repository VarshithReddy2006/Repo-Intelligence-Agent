---
import Layout from '../layouts/Layout.astro';
import ChatInterface from '../components/interactive/ChatInterface';
---

<Layout title="Repository Chat - Repo Intelligence Agent">
  <div class="space-y-6 w-full py-4 flex flex-col flex-grow items-center">
    {/* Page Header */}
    <div class="border-b border-border pb-5 w-full max-w-3xl">
      <div class="text-[10px] font-mono font-bold uppercase tracking-widest text-primary mb-1.5">
        Repository Intelligence
      </div>
      <div class="flex items-start justify-between gap-4">
        <div>
          <h1 class="text-xl font-semibold text-text tracking-tight flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            Repository Chat
          </h1>
          <p class="text-xs text-text-muted mt-1 font-sans leading-relaxed">
            Conversational answers grounded in retrieval, cited file by file. Ask about architecture,
            design choices, or onboarding paths.
          </p>
        </div>

        <!-- Active repo badge — hydrated from localStorage -->
        <div
          id="chat-repo-badge"
          class="hidden shrink-0 text-[10px] font-mono border border-primary/30 text-primary px-2.5 py-1 rounded-md bg-primary/5"
          aria-live="polite"
        ></div>
      </div>
    </div>

    {/* Chat Interface react island — client:only because it reads localStorage during init */}
    <div class="w-full max-w-3xl flex-grow">
      <ChatInterface repoName="" client:only="react" />
    </div>
  </div>
</Layout>

<script>
  function initChatBadge() {
    const badge = document.getElementById('chat-repo-badge');
    if (!badge) return;
    const repo = localStorage.getItem('activeRepo');
    if (repo) {
      badge.textContent = repo;
      badge.classList.remove('hidden');
    }
  }
  initChatBadge();
  document.addEventListener('astro:page-load', initChatBadge);
</script>
