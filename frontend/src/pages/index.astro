---
import Layout from '../layouts/Layout.astro';
import RepoInput from '../components/interactive/RepoInput';

const features = [
  {
    title: 'Dependency Graph',
    description: 'Interactive force-directed map of every file, edge, and cycle in your codebase.',
    icon: `<path d="M5 6h14M5 12h14M5 18h14"/>`,
  },
  {
    title: 'PR Risk Intelligence',
    description: 'Blast radius, symbol diffs, and propagation paths for every pull request.',
    icon: `<path d="M12 2 4 6v6c0 5 3.5 9.4 8 10 4.5-.6 8-5 8-10V6l-8-4Z"/>`,
  },
  {
    title: 'Architecture Drift',
    description: 'Track cycles, coupling shifts, and entry-point changes across releases.',
    icon: `<path d="M12 2v20M2 12h20M4.9 4.9l14.2 14.2M19.1 4.9 4.9 19.1"/>`,
  },
  {
    title: 'Dead Code Analyzer',
    description: 'Surface unreachable modules and orphan chains with cleanup confidence scores.',
    icon: `<path d="M3 6h18M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2M6 6l1 14a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2l1-14"/>`,
  },
  {
    title: 'Reading Path',
    description: 'Ranked onboarding flow — read the right files in the right order.',
    icon: `<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2Z"/>`,
  },
  {
    title: 'Codebase Chat',
    description: 'Conversational answers grounded in retrieval, cited file by file.',
    icon: `<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>`,
  },
];

const pipeline = [
  ['01', 'Clone',   'Shallow clone the target GitHub repo'],
  ['02', 'Detect',  'Languages, frameworks & manifests'],
  ['03', 'Index',   'AST → symbol & dependency graph'],
  ['04', 'Analyze', 'Centrality, cycles, hotspots'],
  ['05', 'Answer',  'Retrieval-grounded responses'],
];

const previewKpis = [
  { label: 'Files',        value: '1,284' },
  { label: 'Symbols',      value: '8,917' },
  { label: 'Components',   value: '32' },
  { label: 'Entry Points', value: '6' },
  { label: 'Health',       value: 'A' },
];

const techStack = {
  frontend: ['Astro', 'React', 'TailwindCSS', 'TypeScript', 'React Flow', 'Framer Motion'],
  backend:  ['FastAPI', 'Python 3.12', 'NetworkX', 'GitHub API', 'Jinja2'],
  ai:       ['Gemini 2.5 Flash', 'ChromaDB', 'Tree-sitter', 'Incremental Analysis'],
};
---

<Layout title="Repo Intelligence Agent — Understand any codebase in minutes">

  {/* ============================================================
        HERO
        ============================================================ */}
  <section class="relative pt-6 pb-12 sm:pt-12 sm:pb-20">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
      <div
        class="absolute top-[-10%] left-1/2 -translate-x-1/2 h-[420px] w-[820px] rounded-full blur-3xl opacity-30"
        style="background: radial-gradient(circle, rgba(94,106,210,0.45) 0%, transparent 65%);"
      ></div>
      <div
        class="absolute inset-0"
        style="background-image: radial-gradient(rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 28px 28px;"
      ></div>
    </div>

    <div class="max-w-4xl mx-auto text-center space-y-6 fade-up px-2">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-border bg-surface-2 text-[11px] font-mono text-text-muted">
        <span class="h-1.5 w-1.5 rounded-full bg-success animate-pulse" aria-hidden="true"></span>
        <span>Multi-agent AI · Kaggle capstone</span>
      </div>

      <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight leading-[1.05]">
        <span class="text-gradient-brand">Understand any codebase</span>
        <br />
        <span class="text-text">in minutes, not weeks.</span>
      </h1>

      <p class="text-base sm:text-lg text-text-muted max-w-2xl mx-auto leading-relaxed">
        Repo Intelligence Agent indexes a GitHub repository, builds a typed dependency graph,
        and answers questions like a senior engineer who's already read the whole thing.
      </p>

      <div class="pt-4">
        <RepoInput client:load />
      </div>
    </div>
  </section>

  {/* ============================================================
        FEATURE CARDS
        ============================================================ */}
  <section class="py-12 sm:py-16" aria-labelledby="features-heading">
    <div class="max-w-6xl mx-auto space-y-8">
      <header class="text-center space-y-2">
        <p class="text-[11px] font-mono uppercase tracking-widest text-primary font-semibold">
          What it does
        </p>
        <h2 id="features-heading" class="text-2xl sm:text-3xl font-semibold text-text tracking-tight">
          A complete comprehension toolkit
        </h2>
      </header>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5">
        {features.map((f) => (
          <article class="card p-5 space-y-3 transition-all hover:border-primary/40 hover:-translate-y-0.5">
            <!-- Icon: proper inline SVG using the icon path -->
            <div
              class="h-9 w-9 rounded-lg border border-primary/30 bg-primary/10 text-primary flex items-center justify-center"
              aria-hidden="true"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={f.icon} />
            </div>
            <h3 class="text-base font-semibold text-text">{f.title}</h3>
            <p class="text-sm text-text-muted leading-relaxed">{f.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ============================================================
        PIPELINE STEPPER
        ============================================================ */}
  <section class="py-12 sm:py-16" aria-labelledby="arch-heading">
    <div class="max-w-6xl mx-auto">
      <div class="card p-6 sm:p-8 space-y-8">
        <header class="space-y-2 max-w-2xl">
          <p class="text-[11px] font-mono uppercase tracking-widest text-primary font-semibold">
            Under the hood
          </p>
          <h2 id="arch-heading" class="text-2xl font-semibold text-text tracking-tight">
            Multi-agent pipeline, deterministic graph core
          </h2>
          <p class="text-sm text-text-muted leading-relaxed">
            Each stage is a focused agent. The graph is built with NetworkX, indexed by symbol,
            and served behind a FastAPI surface. Every answer is cited.
          </p>
        </header>

        <!-- Visual stepper -->
        <ol class="grid grid-cols-1 md:grid-cols-5 gap-0 relative" aria-label="Analysis pipeline stages">
          {pipeline.map(([n, title, desc], idx) => (
            <li class="flex md:flex-col gap-4 md:gap-3 items-start md:items-center text-center relative">
              <!-- Connector line (hidden on mobile) -->
              {idx < pipeline.length - 1 && (
                <div
                  class="hidden md:block absolute top-5 left-[calc(50%+28px)] right-[calc(-50%+28px)] h-px bg-border"
                  aria-hidden="true"
                ></div>
              )}
              <!-- Number circle -->
              <div
                class="relative z-10 shrink-0 h-10 w-10 rounded-full bg-primary/10 border border-primary/30
                       flex items-center justify-center text-[11px] font-mono font-bold text-primary"
                aria-hidden="true"
              >
                {n}
              </div>
              <div class="text-left md:text-center space-y-1">
                <div class="text-sm font-semibold text-text">{title}</div>
                <div class="text-[11px] text-text-muted leading-relaxed font-sans">{desc}</div>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  {/* ============================================================
        DASHBOARD PREVIEW
        ============================================================ */}
  <section class="py-12 sm:py-16" aria-labelledby="preview-heading">
    <div class="max-w-6xl mx-auto space-y-6">
      <header class="text-center space-y-2">
        <p class="text-[11px] font-mono uppercase tracking-widest text-primary font-semibold">
          The dashboard
        </p>
        <h2 id="preview-heading" class="text-2xl sm:text-3xl font-semibold text-text tracking-tight">
          Every metric, one keyboard shortcut away
        </h2>
      </header>

      <div class="card p-6 space-y-5">
        <div class="flex items-center gap-3 pb-4 border-b border-border">
          <div class="h-8 w-8 rounded-md bg-primary/15 border border-primary/30" aria-hidden="true"></div>
          <div class="flex-grow space-y-2">
            <div class="h-3 w-40 rounded bg-surface-2"></div>
            <div class="h-2 w-24 rounded bg-surface-2 opacity-60"></div>
          </div>
          <div class="h-6 w-20 rounded-full bg-success/10 border border-success/30"></div>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-5 gap-3">
          {previewKpis.map((kpi) => (
            <div class="card p-3 flex flex-col gap-1.5">
              <div class="text-[9px] font-mono uppercase tracking-widest text-text-subtle">{kpi.label}</div>
              <div class="text-xl font-extrabold text-text font-mono tracking-tight">{kpi.value}</div>
              <div class="h-1 w-12 rounded-full bg-primary" aria-hidden="true"></div>
            </div>
          ))}
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
          <div class="card-flat p-4 lg:col-span-2 space-y-3">
            <div class="h-2 w-32 rounded bg-surface-2"></div>
            <div class="space-y-2">
              {[60, 40, 80, 30, 70, 50].map((w) => (
                <div class="flex items-center gap-3">
                  <div class="h-2 rounded bg-primary/40" style={`width: ${w}%`}></div>
                  <div class="h-2 w-10 rounded bg-surface-2"></div>
                </div>
              ))}
            </div>
          </div>
          <div class="card-flat p-4 flex flex-col items-center justify-center gap-3">
            <div
              class="h-24 w-24 rounded-full border-[10px] border-border"
              style="border-top-color: var(--primary); border-right-color: var(--primary);"
              aria-hidden="true"
            ></div>
            <div class="h-2 w-20 rounded bg-surface-2"></div>
          </div>
        </div>
      </div>
    </div>
  </section>
  {/* ============================================================
        TECH STACK — grouped by category
        ============================================================ */}
  <section class="py-12" aria-labelledby="tech-heading">
    <div class="max-w-4xl mx-auto space-y-6">
      <p id="tech-heading" class="text-center text-[11px] font-mono uppercase tracking-widest text-text-subtle">
        Powered by
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {Object.entries(techStack).map(([category, items]) => (
          <div class="space-y-2">
            <p class="text-[10px] font-mono uppercase tracking-widest text-text-subtle text-center capitalize">{category}</p>
            <div class="flex flex-wrap justify-center gap-1.5">
              {items.map((t) => (
                <span class="text-xs font-mono px-2.5 py-1 rounded-md border border-border bg-surface-1 text-text-muted hover:text-text hover:border-primary/30 transition-colors">
                  {t}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>
