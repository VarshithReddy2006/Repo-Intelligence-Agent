---
const pathname = new URL(Astro.request.url).pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/issues', label: 'Issue Intelligence' },
  { href: '/chat', label: 'Repository Chat' }
];

// Determine if we are on the analysis page
const isAnalysisActive = pathname.startsWith('/analysis');
---
<header class="sticky top-0 z-50 w-full border-b border-border bg-canvas/80 backdrop-blur-md">
  <div class="mx-auto flex h-14 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <!-- Brand / Logo -->
    <div class="flex items-center gap-6">
      <a href="/" class="flex items-center gap-2 text-md font-semibold tracking-tight text-text hover:text-primary transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#5e6ad2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-bot"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>
        <span>Repo Intelligence <span class="text-primary">Agent</span></span>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-5 text-sm font-medium" id="desktop-nav">
        {navLinks.map(link => {
          const isActive = pathname === link.href;
          return (
            <a
              href={link.href}
              class={`transition-colors hover:text-text ${
                isActive ? 'text-text font-semibold' : 'text-text-muted'
              }`}
            >
              {link.label}
            </a>
          );
        })}
        <a
          id="analysis-nav-link"
          href="#"
          class="transition-colors hover:text-text text-text-muted hidden"
        >
          Analysis Dashboard
        </a>
      </nav>
    </div>

    <!-- Right Side API Status & Actions -->
    <div class="flex items-center gap-4 text-xs font-mono">
      <div class="hidden sm:flex items-center gap-3 border border-border bg-card px-3 py-1.5 rounded-md">
        <div class="flex items-center gap-1.5" id="backend-status-container">
          <span class="h-2 w-2 rounded-full bg-zinc-500 animate-pulse"></span>
          <span class="text-text-muted">BACKEND:</span>
          <span class="text-text">CHECKING</span>
        </div>
        <div class="h-3 w-[1px] bg-border"></div>
        <div class="flex items-center gap-1.5">
          <span class="h-2 w-2 rounded-full bg-emerald-500 animate-pulse"></span>
          <span class="text-text-muted">GEMINI:</span>
          <span class="text-text">ENV</span>
        </div>
        <div class="h-3 w-[1px] bg-border"></div>
        <div class="flex items-center gap-1.5">
          <span class="h-2 w-2 rounded-full bg-emerald-500"></span>
          <span class="text-text-muted">GITHUB:</span>
          <span class="text-text">ACTIVE</span>
        </div>
      </div>

      <a
        href="https://github.com"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-1 text-text-muted hover:text-text transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-github"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
      </a>
    </div>
  </div>
</header>

<script>
  import { checkBackendHealth } from '../lib/api';

  async function updateStatus() {
    const container = document.getElementById('backend-status-container');
    if (!container) return;

    const isOnline = await checkBackendHealth();
    if (isOnline) {
      container.innerHTML = `
        <span class="h-2 w-2 rounded-full bg-emerald-500"></span>
        <span class="text-emerald-500 font-semibold">🟢 Backend Online</span>
      `;
    } else {
      container.innerHTML = `
        <span class="h-2 w-2 rounded-full bg-rose-500 animate-pulse"></span>
        <span class="text-rose-500 font-semibold">🔴 Backend Offline</span>
      `;
    }
  }

  function setupNavbar() {
    const activeRepo = localStorage.getItem('activeRepo');
    const analysisLink = document.getElementById('analysis-nav-link');
    if (analysisLink && activeRepo) {
      const [owner, repo] = activeRepo.split('/');
      analysisLink.setAttribute('href', `/analysis?owner=${owner}&repo=${repo}`);
      analysisLink.classList.remove('hidden');
      
      const pathname = window.location.pathname;
      if (pathname.startsWith('/analysis')) {
        analysisLink.classList.add('text-text', 'font-semibold', 'border-b-2', 'border-primary', 'py-0.5');
        analysisLink.classList.remove('text-text-muted');
      }
    }
  }

  // Check health immediately
  updateStatus();
  // Poll health status
  setInterval(updateStatus, 8000);
  
  // Setup active analysis tab
  setupNavbar();
</script>
