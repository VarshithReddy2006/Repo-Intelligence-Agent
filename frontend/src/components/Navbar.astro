---
const pathname = new URL(Astro.request.url).pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/issues', label: 'Issue Intelligence' },
  { href: '/chat', label: 'Repository Chat' },
];
---
<header class="sticky top-0 z-50 w-full border-b border-border bg-canvas/80 backdrop-blur-md">
  <div class="mx-auto flex h-14 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <!-- Brand -->
    <div class="flex items-center gap-6">
      <a href="/" class="flex items-center gap-2 text-md font-semibold tracking-tight text-text hover:text-primary transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#5e6ad2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>
        <span>Repo Intelligence <span class="text-primary">Agent</span></span>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-5 text-sm font-medium" aria-label="Primary">
        {navLinks.map(link => {
          const isActive = pathname === link.href;
          return (
            <a
              href={link.href}
              aria-current={isActive ? 'page' : undefined}
              class={`transition-colors hover:text-text ${
                isActive ? 'text-text font-semibold' : 'text-text-muted'
              }`}
            >
              {link.label}
            </a>
          );
        })}
        <a
          id="analysis-nav-link"
          href="/analysis"
          class="transition-colors hover:text-text text-text-muted hidden"
        >
          Analysis Dashboard
        </a>
      </nav>
    </div>

    <!-- Right-hand status & actions -->
    <div class="flex items-center gap-4 text-xs font-mono">
      <div
        id="backend-status-container"
        class="hidden sm:flex items-center gap-2 border border-border bg-surface-1 px-3 py-1.5 rounded-md min-w-[160px]"
        role="status"
        aria-live="polite"
      >
        <span id="backend-status-dot" class="h-2 w-2 rounded-full bg-text-subtle animate-pulse" aria-hidden="true"></span>
        <span class="text-text-muted">BACKEND</span>
        <span id="backend-status-label" class="text-text">CHECKING</span>
      </div>

      <a
        href="https://github.com/VarshithReddy2006/Repo-Intelligence-Agent"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="View Repo Intelligence Agent on GitHub"
        class="flex items-center gap-1 text-text-muted hover:text-text transition-colors focus-visible:outline-none focus-visible:shadow-ring rounded"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
      </a>

      <!-- Mobile hamburger — visible below md -->
      <button
        id="mobile-menu-btn"
        type="button"
        class="md:hidden flex items-center justify-center h-8 w-8 rounded-md border border-border bg-surface-1
               text-text-muted hover:text-text hover:border-primary/40 transition-colors
               focus-visible:outline-none focus-visible:shadow-ring"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-nav-dialog"
      >
        <svg id="hamburger-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/></svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Navigation Dialog -->
<dialog
  id="mobile-nav-dialog"
  class="fixed inset-0 z-[60] m-0 p-0 w-full h-full bg-transparent"
  aria-label="Navigation menu"
>
  <!-- Backdrop -->
  <div id="mobile-nav-backdrop" class="absolute inset-0 bg-canvas/80 backdrop-blur-sm"></div>

  <!-- Drawer panel -->
  <div class="absolute top-0 left-0 h-full w-72 bg-surface-1 border-r border-border flex flex-col shadow-float">
    <!-- Header -->
    <div class="flex items-center justify-between px-5 h-14 border-b border-border">
      <span class="text-sm font-semibold text-text">Navigation</span>
      <button
        id="mobile-nav-close"
        type="button"
        class="flex items-center justify-center h-7 w-7 rounded-md text-text-muted hover:text-text
               hover:bg-surface-2 transition-colors focus-visible:outline-none focus-visible:shadow-ring"
        aria-label="Close navigation menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <!-- Links -->
    <nav class="flex flex-col gap-1 p-3 flex-grow" aria-label="Mobile primary navigation">
      {navLinks.map(link => {
        const isActive = pathname === link.href;
        return (
          <a
            href={link.href}
            aria-current={isActive ? 'page' : undefined}
            class={`flex items-center gap-2.5 px-3 py-2.5 rounded-md text-sm font-medium transition-colors ${
              isActive
                ? 'bg-primary/10 text-primary border border-primary/20'
                : 'text-text-muted hover:text-text hover:bg-surface-2'
            }`}
          >
            {link.label}
          </a>
        );
      })}
      <a
        id="mobile-analysis-link"
        href="/analysis"
        class="flex items-center gap-2.5 px-3 py-2.5 rounded-md text-sm font-medium text-text-muted hover:text-text hover:bg-surface-2 transition-colors hidden"
      >
        Analysis Dashboard
      </a>
    </nav>
  </div>
</dialog>

<script>
  import { checkBackendHealth } from '../lib/api';

  // ── Backend status ───────────────────────────────────────────────────────
  async function updateStatus() {
    const dot   = document.getElementById('backend-status-dot');
    const label = document.getElementById('backend-status-label');
    if (!dot || !label) return;

    const isOnline = await checkBackendHealth();
    if (isOnline) {
      dot.className   = 'h-2 w-2 rounded-full bg-success';
      label.textContent = 'ONLINE';
      label.className = 'text-success font-semibold';
    } else {
      dot.className   = 'h-2 w-2 rounded-full bg-danger animate-pulse';
      label.textContent = 'OFFLINE';
      label.className = 'text-danger font-semibold';
    }
  }

  // ── Analysis nav link ────────────────────────────────────────────────────
  function setupNavbar() {
    const analysisLink   = document.getElementById('analysis-nav-link');
    const mobileLink     = document.getElementById('mobile-analysis-link');

    function updateLinks(activeRepo: string | null) {
      if (activeRepo) {
        const [owner, repo] = activeRepo.split('/');
        if (!owner || !repo) return;
        const href = `/analysis?owner=${owner}&repo=${repo}`;

        if (analysisLink) {
          analysisLink.setAttribute('href', href);
          analysisLink.classList.remove('hidden');
          const isAnalysisPage = window.location.pathname.startsWith('/analysis');
          if (isAnalysisPage) {
            analysisLink.setAttribute('aria-current', 'page');
            analysisLink.classList.add('text-text', 'font-semibold');
            analysisLink.classList.remove('text-text-muted');
          } else {
            analysisLink.removeAttribute('aria-current');
            analysisLink.classList.remove('text-text', 'font-semibold');
            analysisLink.classList.add('text-text-muted');
          }
        }

        if (mobileLink) {
          mobileLink.setAttribute('href', href);
          mobileLink.classList.remove('hidden');
        }
      } else {
        if (analysisLink) {
          analysisLink.classList.add('hidden');
          analysisLink.removeAttribute('aria-current');
        }
        if (mobileLink) {
          mobileLink.classList.add('hidden');
        }
      }
    }

    const activeRepo = localStorage.getItem('activeRepo');
    updateLinks(activeRepo);

    // Listen for custom events to update state instantly across pages/islands
    window.addEventListener('active-repo-changed', (e: any) => {
      updateLinks(e.detail);
    });

    window.addEventListener('active-repo-cleared', () => {
      updateLinks(null);
    });
  }

  // ── Mobile menu ──────────────────────────────────────────────────────────
  function setupMobileMenu() {
    const btn     = document.getElementById('mobile-menu-btn');
    const dialog  = document.getElementById('mobile-nav-dialog') as HTMLDialogElement | null;
    const closeBtn= document.getElementById('mobile-nav-close');
    const backdrop= document.getElementById('mobile-nav-backdrop');
    if (!btn || !dialog || !closeBtn || !backdrop) return;

    function openMenu() {
      dialog!.showModal();
      btn!.setAttribute('aria-expanded', 'true');
    }

    // Safely handle closing menu
    const closeMenu = () => {
      if (dialog && dialog.open) {
        dialog.close();
      }
      if (btn) {
        btn.setAttribute('aria-expanded', 'false');
      }
    };

    btn.addEventListener('click', openMenu);
    closeBtn.addEventListener('click', closeMenu);
    backdrop.addEventListener('click', closeMenu);
    dialog.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape') closeMenu();
    });

    // Also support custom event closures
    window.addEventListener('active-repo-cleared', closeMenu);
  }

  updateStatus();
  setInterval(updateStatus, 8000);
  setupNavbar();
  setupMobileMenu();
</script>
