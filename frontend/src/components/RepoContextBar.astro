---
/**
 * RepoContextBar — shows the currently active repository across all pages.
 * Reads from localStorage on the client; renders nothing on the server (SSR-safe).
 * Appears below the navbar when an active repo is stored.
 */
---

<!-- Server renders an empty placeholder; client hydrates it -->
<div
  id="repo-context-bar"
  class="hidden w-full border-b border-border bg-surface-1/60 backdrop-blur-sm"
  role="status"
  aria-live="polite"
  aria-label="Active repository context"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-9 flex items-center justify-between gap-4">
    <!-- Left: repo + meta -->
    <div class="flex items-center gap-3 min-w-0 text-xs font-mono">
      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24"
           fill="none" stroke="var(--primary)" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
        <path d="M9 18c-4.51 2-5-2-7-2"/>
      </svg>
      <a
        id="rcb-repo-link"
        href="#"
        class="text-text hover:text-primary transition-colors truncate max-w-[240px] font-semibold"
        aria-label="Open analysis for active repository"
      ></a>
      <span class="text-border-strong" aria-hidden="true">·</span>
      <span id="rcb-meta" class="text-text-subtle truncate"></span>
    </div>

    <!-- Right: clear button -->
    <button
      id="rcb-clear"
      type="button"
      class="shrink-0 flex items-center gap-1 text-[10px] font-mono text-text-subtle
             hover:text-danger transition-colors focus-visible:outline-none rounded"
      aria-label="Clear active repository context"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2.5"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
      Clear
    </button>
  </div>
</div>

<script>
  function initContextBar() {
    const bar       = document.getElementById('repo-context-bar');
    const linkEl    = document.getElementById('rcb-repo-link');
    const metaEl    = document.getElementById('rcb-meta');
    const clearBtn  = document.getElementById('rcb-clear');
    if (!bar || !linkEl || !metaEl || !clearBtn) return;

    const activeRepo = localStorage.getItem('activeRepo');
    if (!activeRepo) {
      bar.classList.add('hidden');
      return;
    }

    const [owner, repo] = activeRepo.split('/');
    if (!owner || !repo) {
      bar.classList.add('hidden');
      return;
    }

    // Build link
    linkEl.textContent = `${owner} / ${repo}`;
    linkEl.setAttribute('href', `/analysis?owner=${owner}&repo=${repo}`);

    // Build meta: last analysed time if stored
    const lastAnalysed = localStorage.getItem(`lastAnalysed:${activeRepo}`);
    if (lastAnalysed) {
      const diff = Math.round((Date.now() - parseInt(lastAnalysed, 10)) / 60000);
      metaEl.textContent = diff < 2
        ? 'analysed just now'
        : `analysed ${diff} min ago`;
    } else {
      metaEl.textContent = 'analysed recently';
    }

    bar.classList.remove('hidden');

    // Remove any previous listener by cloning and replacing, or simply clear activeRepo
    // Since this script runs on each page/transition, event listener setup should be clean
    const onClearClick = () => {
      localStorage.removeItem('activeRepo');
      bar.classList.add('hidden');
      window.dispatchEvent(new CustomEvent('active-repo-cleared'));
    };
    clearBtn.removeEventListener('click', onClearClick);
    clearBtn.addEventListener('click', onClearClick);
  }

  // Run immediately and also on Astro page transitions
  initContextBar();
  document.addEventListener('astro:page-load', initContextBar);
  window.addEventListener('active-repo-changed', initContextBar);
  window.addEventListener('active-repo-cleared', initContextBar);
</script>
